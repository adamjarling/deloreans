---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const {
  title = t('meta.title'),
  description = t('meta.description'),
} = Astro.props;

const siteUrl = 'https://deloreans.at';
const ogImage = `${siteUrl}/images/logo_with_car.jpeg`;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="de" href={`${siteUrl}/`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}/en/`} />
    <link rel="alternate" hreflang="hu" href={`${siteUrl}/hu/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'de' ? 'de_AT' : lang === 'hu' ? 'hu_HU' : 'en_GB'} />
    <meta property="og:site_name" content="DeLoreans" />

    <!-- Twitter/X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg:         #0A0A0F;
    --bg-alt:     #0F0F1A;
    --pink:       #FF1493;
    --cyan:       #00D4FF;
    --purple:     #9B30FF;
    --white:      #FFFFFF;
    --muted:      rgba(255,255,255,0.55);
    --border:     rgba(255,20,147,0.25);

    --font-display: 'Bebas Neue', sans-serif;
    --font-body:    'Barlow Condensed', sans-serif;

    /* Golden ratio spacing scale — Fibonacci: each value ≈ previous × φ (1.618) */
    --space-1:  5px;   /* micro  */
    --space-2:  8px;   /* xs     */
    --space-3: 13px;   /* sm     */
    --space-4: 21px;   /* md     */
    --space-5: 34px;   /* lg     */
    --space-6: 55px;   /* xl     */
    --space-7: 89px;   /* 2xl    */
    --space-8: 144px;  /* 3xl    */
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--bg);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* Scanline grain overlay — applied via ::after on body */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
  }

  img {
    max-width: 100%;
    display: block;
  }

  a {
    color: var(--cyan);
    text-decoration: none;
  }

  a:hover {
    color: var(--pink);
  }

  section {
    padding: var(--space-7) var(--space-4);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.25em;
    color: var(--pink);
    text-transform: uppercase;
    margin-bottom: var(--space-3);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: 0.03em;
    color: var(--white);
    margin-bottom: var(--space-5);
  }

  /* Neon glow utilities */
  .glow-pink  { text-shadow: 0 0 20px var(--pink),  0 0 40px var(--pink); }
  .glow-cyan  { text-shadow: 0 0 20px var(--cyan),  0 0 40px var(--cyan); }
  .glow-purple{ text-shadow: 0 0 20px var(--purple), 0 0 40px var(--purple); }

  /* Divider */
  .neon-line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, var(--pink), var(--purple));
    margin-bottom: var(--space-5);
    box-shadow: 0 0 12px var(--pink);
  }
</style>
