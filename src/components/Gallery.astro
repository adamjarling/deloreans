---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const photos = [
  { src: "/images/carina_lights.jpeg", alt: t("gallery.alt.1") },
  { src: "/images/IMG_2606.JPG", alt: t("gallery.alt.2") },
  { src: "/images/zoltan_adam_carina.jpeg", alt: t("gallery.alt.3") },
  { src: "/images/IMG_2604.JPG", alt: t("gallery.alt.5") },
];
---

<section class="gallery" id="photos">
  <div class="container">
    <p class="section-label">{t("gallery.label")}</p>
    <h2 class="section-title">{t("gallery.title")}</h2>
    <div class="neon-line"></div>
  </div>

  <div class="gallery__grid">
    {
      photos.map((photo) => (
        <div class="gallery__item">
          <img src={photo.src} alt={photo.alt} loading="lazy" />
          <div class="gallery__item-overlay" />
        </div>
      ))
    }
  </div>
</section>

<style>
  .gallery {
    background: var(--bg-alt);
    padding-bottom: 0;
  }

  .gallery .container {
    padding-bottom: 40px;
  }

  /* Desktop: magazine layout
     [ wide landscape  |  wide  ] [ portrait (tall) ]
     [ square          | landscape] [ portrait (tall) ] */
  .gallery__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 300px 300px;
    grid-template-areas:
      "wide    wide     portrait"
      "sq1     sq2      portrait";
    gap: 3px;
  }

  .gallery__item:nth-child(1) { grid-area: wide; }
  .gallery__item:nth-child(2) { grid-area: portrait; }
  .gallery__item:nth-child(3) { grid-area: sq1; }
  .gallery__item:nth-child(4) { grid-area: sq2; }

  .gallery__item {
    position: relative;
    overflow: hidden;
    background: var(--bg-alt);
  }

  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(90%) contrast(1.05);
    transition:
      filter 0.4s ease,
      transform 0.5s ease;
  }

  .gallery__item:hover img {
    filter: grayscale(20%) contrast(1.1);
    transform: scale(1.03);
  }

  /* Neon edge glow on hover */
  .gallery__item-overlay {
    position: absolute;
    inset: 0;
    border: 1px solid transparent;
    transition:
      border-color 0.3s,
      box-shadow 0.3s;
    pointer-events: none;
  }
  .gallery__item:hover .gallery__item-overlay {
    border-color: rgba(255, 20, 147, 0.4);
    box-shadow: inset 0 0 30px rgba(255, 20, 147, 0.08);
  }

  /* Tablet: compress to 2 equal columns, portrait still spans both rows */
  @media (max-width: 900px) {
    .gallery__grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 240px 240px;
      grid-template-areas:
        "wide    portrait"
        "sq1     portrait";
    }
    /* sq2 (4th photo) falls outside the named areas — place it below */
    .gallery__item:nth-child(4) {
      grid-area: unset;
      grid-column: 1 / -1;
      height: 240px;
    }
  }

  /* Mobile: single column, all photos full width.
     Portrait photo gets a taller cell to honour its natural ratio. */
  @media (max-width: 640px) {
    .gallery__grid {
      grid-template-columns: 1fr;
      grid-template-rows: unset;
      grid-template-areas: unset;
    }

    .gallery__item:nth-child(1),
    .gallery__item:nth-child(2),
    .gallery__item:nth-child(3),
    .gallery__item:nth-child(4) {
      grid-area: unset;
      grid-column: unset;
    }

    /* Landscape photos */
    .gallery__item:nth-child(1),
    .gallery__item:nth-child(3),
    .gallery__item:nth-child(4) {
      aspect-ratio: 4 / 3;
      height: unset;
    }

    /* Portrait photo — full natural height */
    .gallery__item:nth-child(2) {
      aspect-ratio: 3 / 4;
      height: unset;
    }

    .gallery__item img {
      height: 100%;
    }
  }
</style>
