---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const videos = [
  { id: 'waiJKm_FP_g', caption: t('watch.caption') },
  { id: 'oMSiwV3fe1E', caption: t('watch.caption2') },
];
---

<section class="watch" id="watch">
  <div class="container">
    <p class="section-label">{t('watch.label')}</p>
    <h2 class="section-title">{t('watch.title')}</h2>
    <div class="neon-line"></div>

    <div class="watch__grid">
      {videos.map(video => (
        <div class="watch__item">
          <div class="watch__player">
            <iframe
              src={`https://www.youtube.com/embed/${video.id}`}
              title="DeLoreans live performance"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
          <p class="watch__caption">{video.caption}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .watch {
    background: var(--bg);
  }

  .watch__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .watch__player {
    position: relative;
    width: 100%;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow:
      0 0 40px rgba(155,48,255,0.2),
      0 0 80px rgba(255,20,147,0.1);
  }

  .watch__player iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: block;
    background: #000;
    border: none;
  }

  .watch__caption {
    text-align: center;
    margin-top: var(--space-4);
    font-size: 0.88rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .watch__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
