---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
const footerText = t('contact.footer').replace('{year}', String(year));
---
<section class="contact" id="contact">
  <div class="contact__inner">
    <div class="contact__top">
      <img
        src="/images/logo_cropped.png"
        alt="DeLoreans"
        class="contact__logo"
      />
    </div>

    <div class="container">
      <div class="contact__grid">

        <div class="contact__book">
          <p class="section-label">{t('contact.label')}</p>
          <h2 class="section-title">{t('contact.title.1')}<br/>{t('contact.title.2')}</h2>
          <div class="neon-line"></div>
          <p class="contact__body">{t('contact.body')}</p>

          <div class="contact__links">
            <a href="mailto:deloreans.official@gmail.com" class="contact__item">
              <span class="contact__icon">✉</span>
              <span>deloreans.official@gmail.com</span>
            </a>
            <a href="https://deloreans.at" class="contact__item">
              <span class="contact__icon">🌐</span>
              <span>deloreans.at</span>
            </a>
          </div>
        </div>

        <div class="contact__repertoire">
          <p class="section-label">{t('contact.repertoire')}</p>
          <ul class="setlist">
            <li>Bon Jovi</li>
            <li>Whitesnake</li>
            <li>Bryan Adams</li>
            <li>Guns N' Roses</li>
            <li>AC/DC</li>
            <li>The Eagles</li>
            <li>Blind Faith</li>
            <li>{t('contact.more')}</li>
          </ul>
        </div>

      </div>
    </div>

    <div class="contact__footer">
      <p>{footerText}</p>
      <div class="contact__social">
        <a href="https://www.youtube.com/@DeLoreansOfficial" class="contact__social-link" target="_blank" rel="noopener" aria-label="YouTube">
          <svg class="contact__social-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
        <a href="#" class="contact__social-link contact__social-link--placeholder" aria-label="Instagram (coming soon)" title="Instagram — coming soon">
          <svg class="contact__social-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/deloreansrock" target="_blank" rel="noopener" class="contact__social-link" aria-label="Facebook" title="Facebook">
          <svg class="contact__social-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="#" class="contact__social-link contact__social-link--placeholder" aria-label="TikTok (coming soon)" title="TikTok — coming soon">
          <svg class="contact__social-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
          </svg>
        </a>
      </div>
      <p class="contact__tagline">{t('contact.tagline')}</p>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--bg);
    padding: 0;
    position: relative;
    overflow: hidden;
  }

  /* Retro grid floor */
  .contact::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 300px;
    background-image:
      linear-gradient(rgba(155,48,255,0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(155,48,255,0.12) 1px, transparent 1px);
    background-size: 50px 50px;
    -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
    mask-image: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
    pointer-events: none;
  }

  .contact__inner {
    position: relative;
    z-index: 1;
    padding: var(--space-7) var(--space-4) 0;
  }

  .contact__top {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-6);
  }

  .contact__logo {
    width: min(360px, 70vw);
    filter: drop-shadow(0 0 20px rgba(255,20,147,0.4));
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-6);
    align-items: start;
  }

  .contact__body {
    font-size: 1.05rem;
    font-weight: 300;
    color: rgba(255,255,255,0.75);
    line-height: 1.75;
    margin-bottom: var(--space-5);
  }

  .contact__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: 1rem;
    color: var(--cyan);
    transition: color 0.2s;
  }
  .contact__item:hover {
    color: var(--pink);
  }

  .contact__icon {
    font-size: 1.1rem;
    margin-top: 2px;
    flex-shrink: 0;
  }


  /* Setlist */
  .setlist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }

  .setlist li {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding-bottom: var(--space-2);
    transition: color 0.2s;
  }
  .setlist li:hover {
    color: var(--white);
    text-shadow: 0 0 12px var(--cyan);
  }
  .setlist li:last-child {
    border-bottom: none;
    color: var(--pink);
  }

  /* Footer bar */
  .contact__footer {
    margin-top: var(--space-7);
    border-top: 1px solid var(--border);
    padding: var(--space-4) 0 var(--space-5);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.82rem;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  .contact__social {
    display: flex;
    gap: var(--space-3);
  }

  .contact__social-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    transition: color 0.2s;
  }
  .contact__social-link:hover {
    color: var(--pink);
  }

  .contact__social-link--placeholder {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }

  .contact__social-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .contact__tagline {
    font-family: var(--font-display);
    letter-spacing: 0.2em;
    color: var(--pink);
    font-size: 0.9rem;
    text-shadow: 0 0 10px rgba(255,20,147,0.4);
  }

  @media (max-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .contact__footer {
      flex-direction: column;
      gap: var(--space-3);
      text-align: center;
    }
  }
</style>
